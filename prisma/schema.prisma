generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  IDEA
  BUILDING
  PRIVATE_TESTNET
  PUBLIC_TESTNET
  MAINNET
  LIVE
  UPCOMING
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  projects Project[]
}

model Project {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  tagline     String
  description String?
  logoUrl     String?
  website     String?
  twitter     String?
  github      String?
  status      ProjectStatus @default(BUILDING)
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  primitive   String?
  replaces    String?
  demoUrl     String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
}

enum NodeType {
  PROJECT
  PRIMITIVE
  BACKER
}

enum EdgeKind {
  USES
  BACKS
}

model Node {
  id    String   @id @default(uuid())
  slug  String   @unique
  label String
  type  NodeType

  outgoing Edge[] @relation("source")
  incoming Edge[] @relation("target")
}

model Edge {
  id       String   @id @default(uuid())
  sourceId String
  targetId String
  kind     EdgeKind

  source Node @relation("source", fields: [sourceId], references: [id])
  target Node @relation("target", fields: [targetId], references: [id])

  @@unique([sourceId, targetId, kind])
  @@index([sourceId])
  @@index([targetId])
}
